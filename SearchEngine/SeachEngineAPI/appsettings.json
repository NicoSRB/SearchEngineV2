{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RedisCacheOptions": {
    "Configuration": "localhost:6379",
    "InstanceName": "RedisCatching"
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "USE_DB_TYPE": "mongo",
  "Mongo": {
    "ConnectionString": "mongodb://root:password@localhost:27017",
    "Database": "indexerdb"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=indexerdb;Username=postgres;Password=password"
  }
}
